{
  "name": "we-time-tracker",
  "private": true,
  "version": "1.5.1",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:prod": "npm run build && NODE_ENV=production electron .",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:dist": "npm run build && electron-builder",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/inter": "^5.3.0",
    "@fontsource/outfit": "^5.3.0",
    "chart.js": "^4.5.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "eslint": "^10.7.0",
    "lucide": "^1.25.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.whiteeagles.wetimetracker",
    "productName": "WE Time Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.cjs",
      "icon.png"
    ],
    "afterPack": "./scripts/adhoc-sign.cjs",
    "mac": {
      "icon": "icon.png",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
